{
  "name": "cup-treasury",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "wdk:smoke": "tsx scripts/wdk-smoke-test.ts",
    "wdk:policy-demo": "tsx scripts/wdk-policy-demo.ts",
    "wdk:policy-demo:json": "tsx scripts/wdk-policy-demo.ts --json",
    "guarded-proof:generate": "tsx scripts/generate-guarded-proof.ts",
    "guarded-proof:check": "tsx scripts/check-guarded-proof.ts",
    "contract:compile": "hardhat compile",
    "contract:test": "npm run contract:compile && tsx scripts/contract-test.ts",
    "contract:node": "hardhat node",
    "wdk:contract-demo": "npm run contract:compile && tsx scripts/wdk-contract-demo.ts",
    "wdk:contract-demo:json": "npm run contract:compile && tsx scripts/wdk-contract-demo.ts --json",
    "contract-proof:generate": "tsx scripts/generate-contract-proof.ts",
    "contract-proof:check": "tsx scripts/check-contract-proof.ts",
    "proof:manifest": "tsx scripts/generate-proof-manifest.ts",
    "semifinal:verify": "npm run lint && npm run build && npm test && npm run test:coverage && npm run contract:compile && npm run contract:test && npm run wdk:smoke && npm run wdk:policy-demo && npm run wdk:policy-demo:json && npm run wdk:contract-demo:json && npm run guarded-proof:check && npm run contract-proof:generate && npm run contract-proof:check"
  },
  "dependencies": {
    "@tetherto/wdk": "^1.0.0-beta.13",
    "@tetherto/wdk-wallet-evm": "^1.0.0-beta.15",
    "ethers": "^6.17.0",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.14",
    "@openzeppelin/contracts": "^5.6.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "hardhat": "^3.9.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^7",
    "vitest": "^4.1.10"
  }
}
